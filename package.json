{
  "name": "shitposter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "lint": "eslint .",
    "start": "next start",
    "db:generate": "echo 'Database migrations are owned by backend Alembic'",
    "db:migrate": "cd backend && alembic upgrade head",
    "db:migrate:prod": "./scripts/run-migrations.sh",
    "worker": "cd backend && arq app.worker.publisher_worker.WorkerSettings",
    "worker:dev": "cd backend && arq app.worker.publisher_worker.WorkerSettings",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:logs:worker": "docker-compose logs -f backend-worker",
    "docker:build": "docker-compose build",
    "docker:rebuild": "docker-compose build --no-cache",
    "docker:dev": "docker-compose -f docker-compose.yml -f docker-compose.dev.yml up",
    "docker:prod": "docker-compose --profile monitoring up -d",
    "queue:status": "echo 'Inspect ARQ jobs in Redis for backend-worker'",
    "queue:clean": "echo 'Use Redis/ARQ tooling for backend-worker queues'",
    "health": "curl -s http://localhost:8000/api/v1/health | jq",
    "metrics": "curl -s http://localhost:8000/api/v1/health?deep=1",
    "test": "vitest run"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "@sentry/nextjs": "^10.43.0",
    "next": "^16.1.6",
    "react": "19.2.0",
    "react-big-calendar": "^1.19.4",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  }
}
