{
  "name": "shitposter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "lint": "eslint .",
    "start": "next start",
    "docker:up": "docker compose --project-directory .. -f ../docker-compose.yml up -d",
    "docker:down": "docker compose --project-directory .. -f ../docker-compose.yml down",
    "docker:logs": "docker compose --project-directory .. -f ../docker-compose.yml logs -f",
    "docker:logs:worker": "docker compose --project-directory .. -f ../docker-compose.yml logs -f backend-worker",
    "docker:build": "docker compose --project-directory .. -f ../docker-compose.yml build",
    "docker:rebuild": "docker compose --project-directory .. -f ../docker-compose.yml build --no-cache",
    "docker:dev": "docker compose --project-directory .. -f ../docker-compose.yml -f ../docker-compose.dev.yml up",
    "docker:prod": "docker compose --project-directory .. -f ../docker-compose.yml up -d --build",
    "test": "vitest run"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "@sentry/nextjs": "^10.43.0",
    "next": "^16.1.6",
    "react": "19.2.0",
    "react-big-calendar": "^1.19.4",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  }
}
