# Shitposter — environment template
# Copy to `.env` and fill in real values:  cp .env.example .env
#
# `docker-compose.yml` reads every variable below via `${VAR}` or
# `${VAR:-default}` and forwards them to the backend / backend-worker / web
# / nginx services. Anything left blank uses the documented default (or a
# safe fallback) — only `TOKEN_ENCRYPTION_KEY` is strictly required for
# the stack to boot in any non-trivial mode.

# -------------------------------------------------------------------------
# Runtime mode
# -------------------------------------------------------------------------
NODE_ENV=production
ENABLE_DOCS=false
LOG_LEVEL=info
LOG_FORMAT=json

# -------------------------------------------------------------------------
# Database (Postgres)
# -------------------------------------------------------------------------
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=socialposter
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# -------------------------------------------------------------------------
# Public URLs
# -------------------------------------------------------------------------
FRONTEND_PUBLIC_URL=http://localhost
BACKEND_PUBLIC_URL=http://localhost
CORS_ORIGINS=http://localhost
# Used by the Next.js web service:
NEXT_PUBLIC_APP_URL=http://localhost
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_BASE_PATH=
INTERNAL_API_BASE_URL=http://backend:8000

# -------------------------------------------------------------------------
# Sessions / token crypto (REQUIRED)
# -------------------------------------------------------------------------
SESSION_COOKIE_NAME=shitposter_session
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
# At least 32 characters. CHANGE for any non-local deploy — this encrypts
# every social access token + refresh token in the database.
TOKEN_ENCRYPTION_KEY=

# -------------------------------------------------------------------------
# OAuth — login providers
# -------------------------------------------------------------------------
# Google sign-in (developer console → OAuth 2.0 Client IDs)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -------------------------------------------------------------------------
# OAuth — social account connections
# -------------------------------------------------------------------------
# X / Twitter (developer.x.com → OAuth 2.0)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# LinkedIn (developer.linkedin.com → app → Auth)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# TikTok Login Kit v2 (developers.tiktok.com → app)
# Required scopes: user.info.basic, video.upload, video.publish.
# The R2 public domain (or bucket endpoint) MUST be added to the app's
# "Verified Properties" before PULL_FROM_URL uploads will work.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Instagram Login (developers.facebook.com → app with Instagram product)
# Required scopes: instagram_business_basic, instagram_business_content_publish
# (the latter requires Meta App Review).
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# -------------------------------------------------------------------------
# AI providers (text generation)
# -------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-3-5-haiku-latest

# Any OpenAI-compatible endpoint (e.g. Azure OpenAI, OpenRouter, vLLM)
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_DEFAULT_MODEL=

# -------------------------------------------------------------------------
# Video generation (Replicate model gateway — covers Kling, Pika, Luma,
# Hunyuan, Higgsfield-style models, etc.)
# replicate.com → Account → API tokens
# -------------------------------------------------------------------------
REPLICATE_API_TOKEN=

# -------------------------------------------------------------------------
# Cloudflare R2 — object storage for uploaded + generated video
# dash.cloudflare.com → R2 → API Tokens (S3-compatible scope)
# -------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Optional: when set (Cloudflare Custom Domain on the bucket), uploads
# return non-expiring public URLs at <base>/<key>. Leave empty to fall
# back to short-lived presigned GET URLs.
R2_PUBLIC_BASE_URL=
# Default lifetime for presigned URLs (seconds). 24h covers TikTok Inbox
# + Instagram container fetch windows. Max 7d (604800).
R2_SIGNED_URL_EXPIRES=86400

# -------------------------------------------------------------------------
# Polar — billing
# -------------------------------------------------------------------------
POLAR_ACCESS_TOKEN=
POLAR_SERVER_URL=
POLAR_WEBHOOK_SECRET=
POLAR_PRODUCT_ID_BASIC=
POLAR_PRODUCT_ID_BUSINESS=
POLAR_PRODUCT_ID_ENTERPRISE=

# -------------------------------------------------------------------------
# Sentry — error reporting
# -------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_DSN=

# -------------------------------------------------------------------------
# NGINX (production reverse proxy)
# -------------------------------------------------------------------------
NGINX_HTTP_PORT=80
NGINX_SERVER_NAME=_
NGINX_CLIENT_MAX_BODY_SIZE=20m
